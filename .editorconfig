root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py,pyi}]
indent_size = 4

[*.{yaml,yml,json,toml,md,mdx,mjs,js,ts}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

# Snapshots are kept byte-for-byte.
[tests/**/__snapshots__/**]
trim_trailing_whitespace = false
insert_final_newline = false
