---
// Keep Starlight's built-in footer (pagination, edit link, last updated), then
// append project-level links: GitHub and license.
// The built-in footer needs the route props and pagination data, which some
// routes (e.g. the 404 page) do not have, so forward props and guard it.
import Default from "@astrojs/starlight/components/Footer.astro";
---

{Astro.props.pagination && <Default {...Astro.props} />}

<div class="pb-footer">
  <nav class="pb-footer-links" aria-label="Project">
    <a href="https://github.com/frenck/probatio">GitHub</a>
    <span aria-hidden="true">·</span>
    <a href="https://github.com/frenck/probatio/blob/main/LICENSE">License (MIT)</a>
  </nav>
  <p class="pb-footer-copy">
    Released under the <a href="https://github.com/frenck/probatio/blob/main/LICENSE">MIT License</a>. Copyright © 2026{" "}
    <a href="https://github.com/frenck">Franck Nijhof</a>.
  </p>
</div>

<style>
  .pb-footer {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-hairline);
    text-align: center;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .pb-footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  .pb-footer-copy {
    margin-top: 0.5rem;
  }
  .pb-footer a {
    color: var(--sl-color-gray-2);
    text-decoration: none;
  }
  .pb-footer a:hover {
    color: var(--sl-color-accent-high);
    text-decoration: underline;
  }
</style>
